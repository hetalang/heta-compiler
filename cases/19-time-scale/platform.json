{
  "builderVersion": "*",
  "id": "template",
  "notes": "platform notes",
  "version": "v0.1.0",
  "license": "UNLICENSED",
  "options": {
    "unitsCheck": true
  },
  "importModule": {
    "type": "heta",
    "source": "src/index.heta"
  },
  "export": [
    {
      "format": "JSON"
    },
    {
      "format": "YAML"
    },
    {
      "format": "XLSX",
      "omitRows": 3,
      "splitByClass": true
    },
    {
      "format": "SBML",
      "version": "L2V4",
      "spaceFilter": "zzz"
    },
    {
      "format": "SLV",
      "spaceFilter": "zzz"
    },
    {
      "format": "DBSolve",
      "spaceFilter": "zzz"
    },
    {
      "format": "Simbio",
      "spaceFilter": "zzz"
    },
    {
      "format": "Mrgsolve",
      "spaceFilter": "zzz"
    },
    {
      "format": "Matlab",
      "spaceFilter": "zzz"
    },
    {
      "format": "Julia",
      "spaceFilter": "zzz"
    }
  ]
}
