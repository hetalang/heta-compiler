{
  "builderVersion": "*",
  "id": "template",
  "options": {
    "debug": false
  },
  "importModule": {
    "type": "heta",
    "source": "src/index.heta"
  },
  "export": [
    {
      "format": "JSON",
      "spaceFilter": "(nameless)|(one)|(two)",
      "useUnitsExpr": false
    },
    {
      "format": "YAML",
      "spaceFilter": "one",
      "useUnitsExpr": false
    },
    {
      "format": "XLSX",
      "omitRows": 3,
      "splitByClass": true,
      "spaceFilter": "one"
    },
    {
      "format": "HetaCode",
      "spaceFilter": "(one)|(two)"
    },
    {
      "format": "SBML",
      "version": "L2V4",
      "spaceFilter": "(one)|(two)"
    },
    {
      "format": "Simbio"
    },
    {
      "format": "Mrgsolve",
      "spaceFilter": "(nameless)|(one)"
    },
    {
      "format": "SLV",
      "eventsOff": false,
      "spaceFilter": "one"
    },
    {
      "format": "DBSolve",
      "eventsOff": false,
      "spaceFilter": "one"
    },
    {
      "format": "Matlab",
      "spaceFilter": "(nameless)|(one)"
    },
    {
      "format": "Julia",
      "spaceFilter": "nameless"
    }
  ]
}
