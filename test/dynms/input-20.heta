c1 @Compartment .= 5;
x1 @Species { compartment: c1 } .= 1;
x2 @Species { compartment: c1, isAmount: true } .= 2;

pr1 @Reaction {actors: x1=>x2} := k1 * x1;

k1 @Const = 1e-3;

sw1 @TimeSwitcher {
    start: start1
};
x1 [sw1]= (x1*c1 + dose1) / c1;
x2 [sw1]= 0;
dose1 @Const = 15;
start1 @Const = 12;
