{
  "id": "nameless",
  "constants": [
    {
      "id": "k1",
      "value": 0.001
    },
    {
      "id": "start1",
      "value": 12
    },
    {
      "id": "period1",
      "value": 24
    },
    {
      "id": "stop1",
      "value": 100
    }
  ],
  "states": [
    {
      "id": "x1",
      "initial": 1
    },
    {
      "id": "x2",
      "initial": 2
    }
  ],
  "assignments": [
    {
      "id": "pr1",
      "rhs": {
        "expr": "k1 * x1",
        "format": "heta"
      }
    }
  ],
  "derivatives": [
    {
      "state": "x1",
      "rhs": {
        "expr": "-pr1",
        "format": "heta"
      }
    },
    {
      "state": "x2",
      "rhs": {
        "expr": "+pr1",
        "format": "heta"
      }
    }
  ],
  "events": [
    {
      "id": "sw1",
      "trigger": {
        "type": "time",
        "start": {"expr": "start1", "format": "heta"}
      },
      "priority": 0,
      "active": true,
      "actions": [
        { "state": "x1", "rhs": {"expr": "x1 + 10", "format": "heta"} }
      ]
    }
  ],
  "observables": []
}