{
    "plugins": ["plugins/markdown"],
    "opts": {
        "destination": "docs/dev",
        "readme": "docs/api-references.md",
        "recurse": true
    },
    "recurseDepth": 10,
    "source": {
        "include": ["src"],
        "includePattern": ".+\\.js(doc|x)?$",
        "excludePattern": "(^|\\/|\\\\)_"
    },
    "sourceType": "module",
    "tags": {
        "allowUnknownTags": true,
        "dictionaries": ["jsdoc", "closure"]
    },
    "templates": {
        "cleverLinks": false,
        "monospaceLinks": true,
        "default": {
            "outputSourceFiles": false
        }
    }
}
